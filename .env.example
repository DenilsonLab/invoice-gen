# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# JWT_SECRET: Secret key used to sign JSON Web Tokens for authentication.
# Generate a long random string for production.
JWT_SECRET="replace-with-a-long-random-secret"

# GOOGLE_CLIENT_ID: Your Google OAuth Client ID.
# Required for Google Sign-In functionality.
GOOGLE_CLIENT_ID="your-google-client-id"

# GOOGLE_CLIENT_SECRET: Your Google OAuth Client Secret.
# Required for Google Sign-In functionality.
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# TURSO_DATABASE_URL: Optional Turso/libSQL database URL.
# If omitted, the app uses local SQLite at database.sqlite.
TURSO_DATABASE_URL=""

# TURSO_AUTH_TOKEN: Required when connecting to a protected Turso database.
TURSO_AUTH_TOKEN=""
